generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  patient
  doctor
  receptionist
  admin
}

enum AppointmentStatus {
  draft
  booked
  waiting
  submitted
  cancelled
  follow_up
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  role                RoleName
  displayName         String
  isActive            Boolean  @default(true)
  deactivatedAt       DateTime?
  deletedAt           DateTime?
  photoUrl            String?
  photoMimeType       String?
  photoBlob           Bytes?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  doctorProfile       DoctorProfile?
  patientProfile      PatientProfile?
  appointmentsAsDoctor Appointment[] @relation("DoctorAppointments")
  appointmentsAsPatient Appointment[] @relation("PatientAppointments")
  receptionistAssignments ReceptionistDoctorAssignment[] @relation("ReceptionistAssignments")
}

model Role {
  id          String           @id @default(cuid())
  name        RoleName         @unique
  description String?
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model DoctorProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  photoUrl           String?
  phone              String
  registrationNumber String
  licenseNumber      String
  bio                String?
  links              Json     @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  availabilitySlots       DoctorAvailabilitySlot[]
  receptionistAssignments ReceptionistDoctorAssignment[]
}

// Weekly recurring availability slots — up to 5 per doctor
model DoctorAvailabilitySlot {
  id                  String        @id @default(cuid())
  doctorProfileId     String
  dayOfWeek           Int           // 0=Sun, 1=Mon, ..., 6=Sat
  startTime           String        // "HH:MM"
  slotDurationMinutes Int           @default(30)
  createdAt           DateTime      @default(now())

  doctorProfile       DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  @@unique([doctorProfileId, dayOfWeek, startTime])
}

// Admin-managed: which receptionists handle which doctors
model ReceptionistDoctorAssignment {
  id              String        @id @default(cuid())
  receptionistId  String        // User.id of receptionist staff
  doctorProfileId String
  createdAt       DateTime      @default(now())

  receptionist    User          @relation("ReceptionistAssignments", fields: [receptionistId], references: [id], onDelete: Cascade)
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  @@unique([receptionistId, doctorProfileId])
}

model PatientProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  age          Int
  gender       String
  region       String
  phone        String
  aadhar       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Permanent patient identity record — created once at registration, reused across all consultations.
model PatientRecord {
  id                String   @id @default(cuid())
  patientId         String   @unique  // Human-readable: PT-2026-00001
  phone             String   @unique
  email             String?
  fullName          String
  age               Int?
  gender            String?
  heightCm          Float?
  weightKg          Float?
  bmi               Float?
  region            String?
  preferredLanguage String?
  dailyActivity     String?
  comorbidities     Json     @default("[]")
  currentMeds       Json     @default("[]")
  priorSurgery      Boolean  @default(false)
  surgeryDetails    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  appointments   Appointment[]
  submissions    QuestionnaireSubmission[]
  labReports     LabReport[]
}

model Appointment {
  id                 String            @id @default(cuid())
  consultSessionId   String?           @unique
  consultId          String?           @unique  // Human-readable: CSL-20260713-0001
  patientId          String
  patientRecordId    String?           // FK to PatientRecord (set when patient self-registers)
  patientName        String            @default("")
  patientPhone       String            @default("")
  doctorId           String
  doctorName         String            @default("")
  appointmentDate    DateTime
  appointmentTime    String            @default("09:00")
  appointmentType    String            @default("new")
  status             AppointmentStatus @default(booked)
  createdBy          String?
  notes              String?
  videoConsultLink   String?
  preConsultLink     String?
  preConsultSentAt   DateTime?
  confirmationSentAt DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  patient         User              @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctor          User              @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
  patientRecord   PatientRecord?    @relation(fields: [patientRecordId], references: [id], onDelete: SetNull)
  submissions     QuestionnaireSubmission[]
  labReports      LabReport[]
}

model LabReport {
  id              String        @id @default(cuid())
  appointmentId   String
  patientRecordId String?
  fileName        String
  fileType        String        // mri-images | mri-report | xray | labs | other
  storedPath      String?
  fileSizeBytes   Int?
  uploadedAt      DateTime      @default(now())

  appointment     Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientRecord   PatientRecord? @relation(fields: [patientRecordId], references: [id], onDelete: SetNull)
}

model Questionnaire {
  id          String                    @id @default(cuid())
  slug        String                    @unique
  title       String
  subtitle    String
  version     Int                       @default(1)
  audience    Json                      @default("[]")
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  questions   QuestionnaireQuestion[]
  submissions QuestionnaireSubmission[]
}

model QuestionnaireQuestion {
  id              String        @id @default(cuid())
  questionnaireId String
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  key             String
  label           String
  type            String
  helpText        String?
  sortOrder       Int
  config          Json          @default("{}")
}

model QuestionnaireSubmission {
  id              String                    @id @default(cuid())
  questionnaireId String
  appointmentId   String
  patientId       String
  patientRecordId String?
  doctorId        String
  sessionId       String                    @unique
  patientPhone    String?
  status          String
  sectionIndex    Int                       @default(0)
  questionIndex   Int                       @default(0)
  completionPct   Int
  durationSeconds Int
  bmi             Float?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  questionnaire   Questionnaire             @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  appointment     Appointment               @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientRecord   PatientRecord?            @relation(fields: [patientRecordId], references: [id], onDelete: SetNull)
  answers         QuestionnaireAnswer[]

  @@index([patientPhone, updatedAt])
}

model QuestionnaireAnswer {
  id          String                  @id @default(cuid())
  submissionId String
  key         String
  value       Json
  createdAt   DateTime                @default(now())

  submission  QuestionnaireSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model UsageEvent {
  id        String   @id @default(cuid())
  role      RoleName
  eventType String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())
}