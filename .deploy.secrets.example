# Copy to .deploy.secrets and fill your droplet SSH password.
# This file is local-only and should never be committed.
DEPLOY_REMOTE='root@YOUR_DROPLET_IP'
DEPLOY_SSH_PASSWORD='replace_with_your_password'
DEPLOY_CONFIGURE_HTTPS='true'
DEPLOY_HTTPS_DOMAIN='spinexperts.in'
DEPLOY_HTTPS_DOMAIN_ALIASES='www.spinexperts.in'
